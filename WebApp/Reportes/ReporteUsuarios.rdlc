					<rd:TypeName>System.String</rd:TypeName>
				</Field>
				<Field Name="Estado">
					<DataField>Estado</DataField>
					<rd:TypeName>System.String</rd:TypeName>
				</Field>
				<Field Name="FechaCreacion">
					<DataField>FechaCreacion</DataField>
					<rd:TypeName>System.String</rd:TypeName>
				</Field>
			</Fields>
		</DataSet>
	</DataSets>

	<Width>10.2in</Width>
	<Language>es-EC</Language>

	<Page>
