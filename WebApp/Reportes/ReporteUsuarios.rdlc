					<Paragraph>
						<TextRuns>
							<TextRun>
								<Value>=("Generado el: " &amp; Format(Now(), "dd/MM/yyyy HH:mm"))</Value>
								<Style/>
							</TextRun>
						</TextRuns>
					</Paragraph>
				</Paragraphs>
			</Textbox>

