					<rd:TypeName>System.String</rd:TypeName>
				</Field>
				<Field Name="Rol">
					<DataField>Rol</DataField>
					<rd:TypeName>System.String</rd:TypeName>
				</Field>
				<Field Name="LoginUsuario">
