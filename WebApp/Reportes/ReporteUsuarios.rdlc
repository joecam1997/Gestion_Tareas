<?xml version="1.0" encoding="utf-8"?>
<Report xmlns="http://schemas.microsoft.com/sqlserver/reporting/2008/01/reportdefinition"
        xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner">

	<DataSources>
		<DataSource Name="dsUsuarios">
			<ConnectionProperties>
				<DataProvider>System.Data.DataSet</DataProvider>
				<ConnectString>/* local */</ConnectString>
			</ConnectionProperties>
			<rd:DataSourceID>local</rd:DataSourceID>
		</DataSource>
	</DataSources>

	<DataSets>
		<DataSet Name="dsUsuarios">
			<Query>
				<DataSourceName>dsUsuarios</DataSourceName>
				<CommandText>/* local */</CommandText>
			</Query>
			<Fields>
				<Field Name="UsuarioId">
					<DataField>UsuarioId</DataField>
					<rd:TypeName>System.Int32</rd:TypeName>
				</Field>
				<Field Name="Nombre">
