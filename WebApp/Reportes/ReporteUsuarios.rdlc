					<FontFamily>Arial</FontFamily>
					<FontSize>14pt</FontSize>
					<FontWeight>Bold</FontWeight>
					<Color>#1e2235</Color>
				</Style>
				<Top>0in</Top>
				<Left>0in</Left>
				<Height>0.32in</Height>
				<Width>10.2in</Width>
				<Paragraphs>
					<Paragraph>
						<TextRuns>
							<TextRun>
								<Value>Reporte de Usuarios — GestorTareas</Value>
								<Style/>
							</TextRun>
						</TextRuns>
					</Paragraph>
				</Paragraphs>
